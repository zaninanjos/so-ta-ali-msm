<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Truco 2x2 Completo</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="menu">
        <h1>Truco 2x2 Profissional</h1>
        <button onclick="iniciarJogo('sujo')">Jogar Baralho Sujo</button>
        <button onclick="iniciarJogo('limpo')">Jogar Baralho Limpo</button>
    </div>

    <div id="placar" class="escondido">
        <div class="equipe">NÓS: <span id="pontos-nos">0</span></div>
        <div class="equipe">ELES: <span id="pontos-eles">0</span></div>
        <div class="info-rodada">Valor: <span id="valor-rodada">1</span> | Vazas (Nós <span id="vazas-nos">0</span> x <span id="vazas-eles">0</span> Eles)</div>
    </div>

    <div id="mesa-de-truco" class="escondido">
        <div class="jogador topo" id="aliado">
            <span>Aliado (Bot)</span>
            <div class="cartas" id="mao-aliado"></div>
        </div>
        
        <div class="jogador esquerda" id="oponente1">
            <span>Oponente 1</span>
            <div class="cartas" id="mao-oponente1"></div>
        </div>

        <div class="centro-mesa">
            <div id="vira"></div>
            <div id="cartas-jogadas"></div>
        </div>

        <div class="jogador direita" id="oponente2">
            <span>Oponente 2</span>
            <div class="cartas" id="mao-oponente2"></div>
        </div>

        <div class="jogador base" id="voce">
            <span>Você</span>
            <div class="cartas" id="mao-voce"></div>
            <button id="btn-truco" onclick="pedirTruco()">TRUCO!</button>
            <button id="btn-proxima" class="escondido" onclick="novaRodada()">Próxima Mão</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
